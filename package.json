{
  "name": "launchstack",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @launchstack/database db:generate",
    "db:migrate": "pnpm --filter @launchstack/database db:migrate",
    "db:seed": "pnpm --filter @launchstack/database db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
